# Copy to `.env` in this directory for `docker compose` variable substitution.

# X11 display on the Linux host (run `echo $DISPLAY` before `docker compose up`)
DISPLAY=:0

# Host directory bind-mounted to /weights/owl (optional; use when you keep weights in ./weights)
OWL_WEIGHTS_DIR=./weights

# Path *inside the container* to the Flax checkpoint folder (directory with checkpoint files).
# Default in docker-compose: in-repo layout (works with .:/app — no need to copy into ./weights).
# OWL_CHECKPOINT_PATH=/app/detection/OWL_VIT_v2/owl_vit/weights/owl2-b16-960-st-ngrams-curated-ft-lvisbase-ens-cold-weight-05/owl2-b16-960-st-ngrams-curated-ft-lvisbase-ens-cold-weight-05_209b65b
#
# If you use OWL_WEIGHTS_DIR instead, point here at the mount:
# OWL_CHECKPOINT_PATH=/weights/owl

# Optional: passed to JAX/XLA (e.g. --xla_gpu_cuda_data_dir=...)
# XLA_FLAGS=

# GPU visibility (Linux + NVIDIA Container Toolkit)
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility

# improved_pipelines: on-device object store (images/, labels/, classes.txt)
# OBJECT_STORE_ROOT=/app/data/object_store

# Chroma persistence directory for preloaded embeddings
# CHROMA_PERSIST_DIR=/app/data/chroma_db

# Optional: MLflow tracking (local example: file:./mlruns)
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_RUN_NAME=preload_dev

# JSON summary written by preload (used as DVC output)
# PRELOAD_SUMMARY_OUT=/app/data/preload_run_summary.json

# Airflow DAG: repo root when task runs dvc repro
# OPEN_ROBO_VISION_ROOT=/app
